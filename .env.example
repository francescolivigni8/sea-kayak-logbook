APP_NAME="Sea Kayak Logbook"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
ASSET_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Leave SESSION_DOMAIN unset on Laravel Cloud unless you have a deliberate custom-domain cookie plan.
# SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local default. Production should use Resend SMTP or another real provider.
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

KAYAK_MEDIA_DISK=public
KAYAK_MEDIA_TEMPORARY_URLS=false
KAYAK_MEDIA_TEMPORARY_URL_MINUTES=30
KAYAK_OWNER_EMAILS=
KAYAK_INVITE_ONLY=false
KAYAK_INVITE_EMAILS=
KAYAK_PUBLIC_PROFILES_ENABLED=false
KAYAK_NOINDEX=true
# Production hardening checklist:
# APP_DEBUG=false
# SESSION_SECURE_COOKIE=true
# SESSION_ENCRYPT=true
# KAYAK_INVITE_ONLY=true while access remains private/beta
# For production object storage, set both disks to s3 and require expiring media URLs:
# FILESYSTEM_DISK=s3
# KAYAK_MEDIA_DISK=s3
# KAYAK_MEDIA_TEMPORARY_URLS=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Optional: Stormglass weather autofill for sessions and Garmin imports.
STORMGLASS_API_KEY=
# STORMGLASS_SOURCE=sg
# STORMGLASS_TIMEOUT=10

# Planning forecast fallback. Open-Meteo can work without a key for non-commercial use.
OPEN_METEO_ENABLED=true
OPEN_METEO_API_KEY=
# OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
# OPEN_METEO_MARINE_BASE_URL=https://marine-api.open-meteo.com/v1/marine

# Optional future atmospheric enrichment from MET Norway.
MET_NO_ENABLED=false
MET_NO_USER_AGENT="Your Kayaking Journal/1.0 hello@yourkayakingjournal.com"

# Production map tiles. Leave open for public OSM/CARTO/OpenTopoMap fallbacks.
MAP_PROVIDER=open
MAPTILER_API_KEY=
MAPTILER_WEATHER_ENABLED=true
# MAP_PROVIDER=maptiler

# Product analytics. Keep disabled until the privacy copy and consent stance are final.
POSTHOG_ENABLED=false
POSTHOG_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# Error monitoring / uptime. Sentry needs the Laravel SDK before server errors are sent.
SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_SEND_DEFAULT_PII=false
BETTER_STACK_UPTIME_MONITOR_URL="${APP_URL}/health"
BETTER_STACK_HEARTBEAT_URL=

# Resend SMTP production example:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.resend.com
# MAIL_PORT=587
# MAIL_USERNAME=resend
# MAIL_PASSWORD="${RESEND_API_KEY}"
# RESEND_API_KEY=
# MAIL_FROM_ADDRESS="hello@yourkayakingjournal.com"

VITE_APP_NAME="${APP_NAME}"
