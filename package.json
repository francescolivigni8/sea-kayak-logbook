{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "postinstall": "node scripts/ensure-local-node.cjs",
        "build": "node scripts/build-with-heartbeat.cjs",
        "build:ssr": "node scripts/run-vite.cjs build && node scripts/run-vite.cjs build --ssr",
        "dev": "node scripts/run-vite.cjs",
        "format": "prettier --write resources/",
        "format:check": "prettier --check resources/",
        "ios:add": "node scripts/ios-add.cjs",
        "ios:assets": "node scripts/ios-assets.cjs",
        "ios:check": "node scripts/check-ios-toolchain.cjs",
        "ios:open": "node scripts/ios-open.cjs",
        "ios:sync": "node scripts/ios-sync.cjs",
        "ios:copy": "./node_modules/.bin/cap copy ios",
        "ios:doctor": "./node_modules/.bin/cap doctor ios",
        "ios:prepare": "npm run build && npm run ios:assets",
        "mobile:sync": "npm run build && npm run ios:sync",
        "lint": "eslint . --fix",
        "wayfinder:generate": "php artisan wayfinder:generate --with-form --ansi",
        "lint:check": "npm run wayfinder:generate && eslint .",
        "test:check": "node scripts/test-with-heartbeat.cjs",
        "types:check": "node scripts/types-check.cjs",
        "verify": "node scripts/verify.cjs"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@laravel/vite-plugin-wayfinder": "^0.1.3",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@tailwindcss/vite": "^4.1.11",
        "@types/node": "^22.13.5",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/eslint-config-typescript": "^14.3.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-vue": "^9.32.0",
        "node": "^22.14.0",
        "prettier": "^3.4.2",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.23.0",
        "vite": "^7.3.2",
        "vue-tsc": "^2.2.4"
    },
    "dependencies": {
        "@capacitor/app": "^8.1.0",
        "@capacitor/cli": "^8.3.3",
        "@capacitor/core": "^8.3.3",
        "@capacitor/ios": "^8.3.3",
        "@capacitor/keyboard": "^8.0.3",
        "@capacitor/preferences": "^8.0.1",
        "@capacitor/share": "^8.0.1",
        "@capacitor/splash-screen": "^8.0.1",
        "@capacitor/status-bar": "^8.0.2",
        "@inertiajs/vite": "^3.0.0",
        "@inertiajs/vue3": "^3.0.0",
        "@maptiler/sdk": "^4.0.1",
        "@maptiler/weather": "^3.1.1",
        "@types/leaflet": "^1.9.21",
        "@vueuse/core": "^12.8.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "laravel-vite-plugin": "^2.1.0",
        "leaflet": "^1.9.4",
        "lucide-vue-next": "^0.468.0",
        "reka-ui": "^2.6.1",
        "tailwind-merge": "^3.2.0",
        "tailwindcss": "^4.1.1",
        "tw-animate-css": "^1.2.5",
        "vue": "^3.5.13",
        "vue-input-otp": "^0.3.2"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.9.5",
        "@rollup/rollup-win32-x64-msvc": "4.9.5",
        "@tailwindcss/oxide-linux-x64-gnu": "^4.0.1",
        "@tailwindcss/oxide-win32-x64-msvc": "^4.0.1",
        "lightningcss-linux-x64-gnu": "^1.29.1",
        "lightningcss-win32-x64-msvc": "^1.29.1"
    }
}
